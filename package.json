{
  "name": "iobroker.parcel",
  "version": "0.3.1",
  "description": "Parcel tracking",
  "author": {
    "name": "TA2k",
    "email": "tombox2020@gmail.com"
  },
  "homepage": "https://github.com/TA2k/ioBroker.parcel",
  "license": "MIT",
  "keywords": [
    "parcel",
    "tracking",
    "dhl",
    "briefe",
    "dpd",
    "gls",
    "hermes",
    "ups",
    "amazon",
    "paket",
    "ioBroker"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/TA2k/ioBroker.parcel"
  },
  "dependencies": {
    "@iobroker/adapter-core": "^3.4.1",
    "axios": "^1.18.1",
    "http-cookie-agent": "^8.0.0",
    "jsdom": "^29.1.1",
    "json2iob": "^2.6.25",
    "qs": "^6.15.3",
    "tough-cookie": "^6.0.1"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
    "@alcalzone/release-script-plugin-license": "^5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "^5.2.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@iobroker/testing": "^5.2.2",
    "@types/node": "^22.20.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "typescript": "~6.0.3"
  },
  "main": "main.js",
  "files": [
    "admin{,/!(src)/**}/!(tsconfig|tsconfig.*).json",
    "admin{,/!(src)/**}/*.{html,css,png,svg,jpg,js}",
    "lib/",
    "www/",
    "io-package.json",
    "LICENSE",
    "main.js"
  ],
  "scripts": {
    "test:js": "mocha --config test/mocharc.custom.json \"{!(node_modules|test)/**/*.test.js,*.test.js,test/**/test!(PackageFiles|Startup).js}\"",
    "test:package": "mocha test/package --exit",
    "test:unit": "mocha test/unit --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run test:js && npm run test:package",
    "check": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint",
    "release": "release-script --all"
  },
  "bugs": {
    "url": "https://github.com/TA2k/ioBroker.parcel/issues"
  },
  "readmeFilename": "README.md",
  "engines": {
    "node": ">=22"
  }
}
